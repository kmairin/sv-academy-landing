RewriteEngine Off
DirectoryIndex index.html

<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable" "expr=%{REQUEST_URI} =~ /\.(png|jpg|jpeg|webp|svg|woff2|js)\$/"
  Header set Cache-Control "no-cache, must-revalidate" "expr=%{REQUEST_URI} =~ /\.html\$/"
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|gif)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/svg+xml .svg
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
